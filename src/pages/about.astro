---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/site";
import { graph, personSchema, websiteSchema } from "../utils/seo";
---

<BaseLayout
  title={`About | ${profile.domain}`}
  description={profile.intro}
  canonicalPath="/about/"
  jsonLd={graph(personSchema, websiteSchema)}
  ogType="profile"
>
  <main>
    <article class="article">
      <header class="article-header">
        <p class="eyebrow">About</p>
        <h1>{profile.name}</h1>
        <p>{profile.intro}</p>
      </header>
      <div class="prose">
        <p>
          This is a small personal site for notes, technical musings, and project
          writeups. It is built with Astro and uses Markdown files for content.
        </p>
        <p>
          You can find the source on <a href={profile.github}>GitHub</a> or get
          in touch at <a href={`mailto:${profile.email}`}>{profile.email}</a>.
        </p>
        <p class="social-links">
          <a href={profile.linkedin}>LinkedIn</a>
          <a href={profile.x}>X</a>
          <a href={profile.github}>GitHub</a>
        </p>
      </div>
    </article>
  </main>
</BaseLayout>
