---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/site";
import {
  absoluteUrl,
  blogSchema,
  graph,
  personSchema,
  tagSlug,
  websiteSchema,
} from "../utils/seo";

const pageTitle = `${profile.name} | ${profile.domain}`;
const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    dateStyle: "medium",
    timeZone: "UTC",
  }).format(date);

const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).sort();

const postItems = posts.map((post, index) => {
  const url = absoluteUrl(`/blog/${post.id}/`);

  return {
    "@type": "BlogPosting",
    "@id": `${url}#article`,
    position: index + 1,
    headline: post.data.title,
    description: post.data.description,
    url,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
    keywords: post.data.tags,
    image: post.data.images.map((image) => absoluteUrl(image)),
    author: {
      "@id": "https://www.charlesw.dev/#person",
    },
    publisher: {
      "@id": "https://www.charlesw.dev/#person",
    },
    isPartOf: {
      "@id": "https://www.charlesw.dev/#blog",
    },
    inLanguage: "en-CA",
  };
});

const homeBlogSchema = {
  ...blogSchema,
  blogPost: postItems.map((post) => ({
    "@id": post["@id"],
  })),
};

const itemListSchema = {
  "@type": "ItemList",
  "@id": "https://www.charlesw.dev/#posts",
  name: `${profile.domain} posts`,
  itemListElement: postItems.map((post) => ({
    "@type": "ListItem",
    position: post.position,
    url: post.url,
    item: {
      "@id": post["@id"],
    },
  })),
};
---

<BaseLayout
  title={pageTitle}
  description={profile.intro}
  canonicalPath="/"
  jsonLd={graph(personSchema, websiteSchema, homeBlogSchema, itemListSchema, ...postItems)}
>
  <main>
    <section class="blog-hero" aria-label="Introduction">
      <p class="eyebrow">{profile.role}</p>
      <h1>{profile.domain}</h1>
      <p class="lede">{profile.intro}</p>
    </section>

    {
      tags.length > 0 && (
        <section class="topic-strip" aria-label="Topics">
          <p class="section-label">Topics</p>
          <ul class="topic-list">
            {tags.map((tag) => (
              <li>
                <a href={`/tags/${tagSlug(tag)}/`}>{tag}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="post-list" aria-label="Posts">
      {
        posts.map((post) => (
          <article class="post-preview">
            <a href={`/blog/${post.id}/`}>
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <ul aria-label="Tags">
                  {post.data.tags.map((tag) => <li>{tag}</li>)}
                </ul>
              )}
            </a>
          </article>
        ))
      }
    </section>
  </main>
</BaseLayout>
