---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import {
  absoluteUrl,
  blogSchema,
  breadcrumbSchema,
  graph,
  personSchema,
  tagSlug,
  websiteSchema,
} from "../../utils/seo";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    dateStyle: "long",
    timeZone: "UTC",
  }).format(date);

const articleClasses = ["article", post.id === "getting-here" && "timeline-post"]
  .filter(Boolean)
  .join(" ");

const postUrl = absoluteUrl(`/blog/${post.id}/`);
const postImages = post.data.images.map((image) => absoluteUrl(image));
const articleSchema = {
  "@type": "BlogPosting",
  "@id": `${postUrl}#article`,
  headline: post.data.title,
  description: post.data.description,
  url: postUrl,
  image: postImages,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    "@id": "https://www.charlesw.dev/#person",
  },
  publisher: {
    "@id": "https://www.charlesw.dev/#person",
  },
  isPartOf: {
    "@id": "https://www.charlesw.dev/#blog",
  },
  mainEntityOfPage: {
    "@id": `${postUrl}#webpage`,
  },
  keywords: post.data.tags,
  inLanguage: "en-CA",
};

const breadcrumbs = [
  { label: "Blog", href: "/" },
  { label: post.data.title, href: `/blog/${post.id}/` },
];
---

<BaseLayout
  title={`${post.data.title} | charlesw.dev`}
  description={post.data.description}
  canonicalPath={`/blog/${post.id}/`}
  image={post.data.images[0]}
  jsonLd={graph(
    personSchema,
    websiteSchema,
    blogSchema,
    breadcrumbSchema([
      { name: "Blog", path: "/" },
      { name: post.data.title, path: `/blog/${post.id}/` },
    ]),
    articleSchema,
  )}
  keywords={post.data.tags}
  ogType="article"
>
  <main>
    <article class={articleClasses}>
      <header class="article-header">
        <Breadcrumbs items={breadcrumbs} />
        <time datetime={post.data.pubDate.toISOString()}>
          {formatDate(post.data.pubDate)}
        </time>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
        {
          post.data.tags.length > 0 && (
            <ul class="article-tags" aria-label="Tags">
              {post.data.tags.map((tag) => (
                <li>
                  <a href={`/tags/${tagSlug(tag)}/`}>{tag}</a>
                </li>
              ))}
            </ul>
          )
        }
      </header>
      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>
